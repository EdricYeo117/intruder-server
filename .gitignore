# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.vscode/.python
pip-wheel-metadata/

# --- Environment / secrets ---
.env
**/.env
.env.*
!.env.example

# --- Uploads / generated media ---
uploads/
drone_photos/
drone_videos/
drone_live_frames/
drone_human_frames/
*.jpg
*.jpeg
*.png
*.mp4
*.mov
*.h264
*.h265
*.csv

